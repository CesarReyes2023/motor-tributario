<Window x:Class="LibroFiscal.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:LibroFiscal.Desktop.ViewModels"
        xmlns:views="clr-namespace:LibroFiscal.Desktop.Views"
        mc:Ignorable="d"
        Title="LibroFiscal" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgAppBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- DataTemplates for MVVM Routing -->
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CompanyViewModel}">
            <views:CompanyView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:DteListViewModel}">
            <views:DteListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CreateDteViewModel}">
            <views:CreateDteView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:OcrScannerViewModel}">
            <views:OcrScannerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:PurchasesViewModel}">
            <views:PurchasesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:VatBooksViewModel}">
            <views:VatBooksView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:IngestionViewModel}">
            <views:IngestionView/>
        </DataTemplate>

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <!-- Add Command property forwarding to internal ButtonBase -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                <Path x:Name="Icon" Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                      Fill="{TemplateBinding Foreground}" Width="18" Height="18" Stretch="Uniform"/>
                                <TextBlock Text="{TemplateBinding Content}" Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A6366F1"/> <!-- 10% opacity primary -->
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/> <!-- TitleBar -->
            <RowDefinition Height="*"/>  <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" Background="{DynamicResource BgAppBrush}" Panel.ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- App Icon & Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                <Path Data="{StaticResource Icon_Dashboard}" Fill="{DynamicResource PrimaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                <TextBlock Text="LibroFiscal" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Window Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource TitleBarButton}" Click="BtnMinimize_Click">
                    <Path Data="{StaticResource Icon_Minimize}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="10" Height="10" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource TitleBarButton}" Click="BtnMaximize_Click">
                    <Path Data="{StaticResource Icon_Maximize}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="10" Height="10" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource TitleBarCloseButton}" Click="BtnClose_Click">
                    <Path Data="{StaticResource Icon_Close}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="10" Height="10" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{DynamicResource BgAppBrush}" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="0,1,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- User Profile -->
                    <Border Grid.Row="0" Margin="20,20,20,30" Background="{DynamicResource BgPanelBrush}" CornerRadius="8" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="36" Height="36" Fill="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Grid.Column="0" Text="CR" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Cesar Reyes" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Premium Plan" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="MENU PRINCIPAL" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="25,0,0,10"/>
                        <RadioButton Content="Dashboard" Tag="{StaticResource Icon_Dashboard}" Style="{StaticResource NavButtonStyle}" IsChecked="True" Command="{Binding NavigateToDashboardCommand}"/>
                        <RadioButton Content="Empresas" Tag="{StaticResource Icon_Company}" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToCompaniesCommand}"/>
                        <RadioButton Content="DTE Emitidos" Tag="{StaticResource Icon_Invoice}" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToDtesCommand}"/>
                        <RadioButton Content="Nueva Factura" Tag="{StaticResource Icon_Book}" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToCreateDteCommand}"/>
                        <RadioButton Content="Lector OCR" Tag="{StaticResource Icon_Book}" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToOcrScannerCommand}"/>
                        <RadioButton Content="Ingesta Masiva" Tag="{StaticResource Icon_Book}" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToIngestionCommand}"/>
                        <RadioButton Content="Libro de Compras" Tag="{StaticResource Icon_Book}" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToPurchasesCommand}"/>
                        <RadioButton Content="Libros IVA" Tag="{StaticResource Icon_Book}" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToVatBooksCommand}"/>
                    </StackPanel>

                    <!-- Bottom Nav -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <Button Style="{StaticResource OutlineButton}" Command="{Binding ToggleThemeCommand}" Margin="20,0,20,10" Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{DynamicResource Icon_Moon}" Fill="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                <TextBlock Text="Cambiar Tema" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <RadioButton Content="Configuración" Tag="{StaticResource Icon_Settings}" Style="{StaticResource NavButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT AREA -->
            <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="0,1,0,0">
                <ContentControl Content="{Binding CurrentViewModel}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Focusable="False"/>
            </Border>
        </Grid>
    </Grid>
</Window>
