<UserControl x:Class="LibroFiscal.Desktop.Views.CreateDteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Emitir Nueva Factura (DTE)" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Complete los datos del receptor y los ítems a facturar" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN (Receptor & Items) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Receptor Data -->
                <Border Grid.Row="0" Background="{DynamicResource BgAppBrush}" CornerRadius="8" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="DATOS DEL CLIENTE (RECEPTOR)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,15"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nombre o Razón Social" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ReceptorNombre, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                         BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                         Padding="10" Height="40"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="NIT o DUI (Opcional)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ReceptorNit, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                         BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                         Padding="10" Height="40"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Items Section -->
                <Border Grid.Row="1" Background="{DynamicResource BgAppBrush}" CornerRadius="8" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="ÍTEMS DE LA FACTURA" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,15"/>

                        <!-- Add Item Bar -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Text="{Binding NuevoItemDescripcion, UpdateSourceTrigger=PropertyChanged}" ToolTip="Descripción del ítem" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="10" Height="40"/>
                            
                            <TextBox Grid.Column="2" Text="{Binding NuevoItemCantidad, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="10" Height="40" ToolTip="Cantidad"/>
                            
                            <TextBox Grid.Column="4" Text="{Binding NuevoItemPrecio, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="10" Height="40" ToolTip="Precio Unitario ($)"/>

                            <Button Grid.Column="6" Content="+" Command="{Binding AgregarItemCommand}" Width="40" Height="40" Style="{StaticResource PrimaryButton}" Padding="0"/>
                        </Grid>

                        <!-- Items List -->
                        <ListView Grid.Row="2" ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Cant." DisplayMemberBinding="{Binding Cantidad}" Width="50"/>
                                    <GridViewColumn Header="Descripción" DisplayMemberBinding="{Binding Descripcion}" Width="250"/>
                                    <GridViewColumn Header="Precio U." DisplayMemberBinding="{Binding PrecioUnitario, StringFormat=C}" Width="90"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT COLUMN (Summary) -->
            <Border Grid.Column="2" Background="{DynamicResource BgAppBrush}" CornerRadius="8" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="25">
                <StackPanel>
                    <TextBlock Text="RESUMEN" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="SubTotal" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding SubTotal, StringFormat=C}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="IVA (13%)" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TotalIva, StringFormat=C}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Retención / Percepción" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TotalRetencion, StringFormat=C}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource BgBorderBrush}" Margin="0,10,0,20"/>

                    <Grid Margin="0,0,0,30">
                        <TextBlock Text="TOTAL A PAGAR" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalPagar, StringFormat=C}" Foreground="{DynamicResource PrimaryBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Content="EMITIR FACTURA" Command="{Binding EmitirDteCommand}" Style="{StaticResource PrimaryButton}" Height="50" FontSize="15"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
