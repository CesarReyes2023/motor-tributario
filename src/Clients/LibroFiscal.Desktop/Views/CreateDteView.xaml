<UserControl x:Class="LibroFiscal.Desktop.Views.CreateDteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1020">

    <Grid Margin="36,32,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="3" Height="28" CornerRadius="2"
                            Background="{DynamicResource EmeraldBrush}"
                            Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Nueva Factura" Style="{StaticResource TextH1}"/>
                </StackPanel>
                <TextBlock Text="EMISIÓN DE DOCUMENTO TRIBUTARIO ELECTRÓNICO (DTE)"
                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="15,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 2-Column layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Receptor + Items -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Card: Receptor -->
                <Border Grid.Row="0"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="22">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="#1510B981">
                                <Path Data="{StaticResource Icon_Company}"
                                      Fill="{DynamicResource EmeraldBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="DATOS DEL CLIENTE (RECEPTOR)" Style="{StaticResource TextLabel}"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="NOMBRE O RAZÓN SOCIAL" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding ReceptorNombre, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="NIT O DUI (OPCIONAL)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding ReceptorNit, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card: Items -->
                <Border Grid.Row="2"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="#1500D4FF">
                                <Path Data="{StaticResource Icon_Invoice}"
                                      Fill="{DynamicResource PrimaryBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ÍTEMS DE LA FACTURA" Style="{StaticResource TextLabel}"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Add Item Bar -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource BgHoverBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding NuevoItemDescripcion, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Descripción del ítem"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding NuevoItemCantidad, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Cantidad" TextAlignment="Center"/>
                                <TextBox Grid.Column="4"
                                         Text="{Binding NuevoItemPrecio, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Precio unitario ($)" TextAlignment="Right"
                                         FontFamily="Consolas"/>
                                <Button Grid.Column="6" Command="{Binding AgregarItemCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Width="40" Padding="0" Height="42">
                                    <Path Data="{StaticResource Icon_Plus}"
                                          Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Items DataGrid -->
                        <DataGrid Grid.Row="4" ItemsSource="{Binding Items}"
                                  IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CANT." Width="70"
                                                    Binding="{Binding Cantidad}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                            <Setter Property="Margin" Value="16,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="DESCRIPCIÓN" Width="*"
                                                    Binding="{Binding Descripcion}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Margin" Value="16,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="PRECIO U." Width="120"
                                                    Binding="{Binding PrecioUnitario, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                            <Setter Property="Margin" Value="16,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="TOTAL" Width="120"
                                                    Binding="{Binding TotalLinea, StringFormat=C2}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                            <Setter Property="Margin" Value="16,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT: Summary + Emit -->
            <Border Grid.Column="2"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BgBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="28" Height="28" CornerRadius="6"
                                Background="#1500D4FF">
                            <Path Data="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Width="14" Height="14" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="RESUMEN" Style="{StaticResource TextLabel}"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Subtotals -->
                    <StackPanel Grid.Row="1">
                        <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <TextBlock Text="SUBTOTAL" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SubTotal, StringFormat=C2}"
                                           FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <TextBlock Text="IVA (13%)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalIva, StringFormat=C2}"
                                           FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AmberBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource BgHoverBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                            <Grid>
                                <TextBlock Text="RETENCIÓN" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalRetencion, StringFormat=C2}"
                                           FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Divider -->
                        <Border Height="1" Background="{DynamicResource BgBorderBrush}" Margin="0,0,0,16"/>

                        <!-- Total -->
                        <Border CornerRadius="8" Padding="16,14">
                            <Border.Background><SolidColorBrush Color="#1000D4FF"/></Border.Background>
                            <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="0,0,0,0" CornerRadius="8">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="TOTAL A PAGAR" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TotalPagar, StringFormat=C2}"
                                               FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Border>
                    </StackPanel>

                    <!-- Emit button -->
                    <Button Grid.Row="2"
                            Command="{Binding EmitirDteCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="50" FontSize="14" FontWeight="Bold"
                            Margin="0,24,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Invoice}"
                                  Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="EMITIR FACTURA" Margin="10,0,0,0" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
