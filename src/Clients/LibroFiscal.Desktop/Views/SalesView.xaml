<UserControl x:Class="LibroFiscal.Desktop.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Libro de Ventas" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Registra ventas a clientes y emite facturas PDF al instante" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding ExportToCsvCommand}" 
                        Style="{StaticResource OutlineButton}" Padding="16,8" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↓" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Exportar CSV"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding LoadSalesCommand}" 
                        Style="{StaticResource PrimaryButton}" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⟳" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Refrescar"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Messages -->
        <Border Grid.Row="1" Background="#1A4CAF50" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#4CAF50" FontWeight="Medium" TextWrapping="Wrap"/>
        </Border>

        <Border Grid.Row="1" Background="#1AF44336" BorderBrush="#F44336" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" FontWeight="Medium" TextWrapping="Wrap"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Form -->
            <Border Grid.Column="0" Background="{DynamicResource BgHoverBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Registrar Venta" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Nombre del Cliente" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="NIT del Cliente" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding CustomerNit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="Número de Documento" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding DocumentNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="Total de la Venta ($)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding TotalAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24"/>

                        <Button Content="Registrar Venta" Command="{Binding RegisterSaleCommand}" Style="{StaticResource PrimaryButton}" Height="40"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Table -->
            <Border Grid.Column="2" Background="{DynamicResource BgHoverBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid>
                    <DataGrid ItemsSource="{Binding Sales}" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" 
                              Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="{DynamicResource BgCardBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding IssueDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Documento" Binding="{Binding DocumentNumber}" Width="100"/>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C2}" Width="100"/>
                            
                            <!-- Action Column -->
                            <DataGridTemplateColumn Header="Acciones" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Imprimir PDF" Command="{Binding DataContext.PrintPdfCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource OutlineButton}" Height="24" Padding="8,0" FontSize="11"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Loading -->
                    <Border Background="#CC080B10" CornerRadius="8" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Cargando..." Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
