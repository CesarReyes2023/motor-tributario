<UserControl x:Class="LibroFiscal.Desktop.Views.DteListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1020">

    <Grid Margin="36,32,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>     <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="3" Height="28" CornerRadius="2"
                            Background="{DynamicResource PrimaryBrush}"
                            Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="DTE Emitidos" Style="{StaticResource TextH1}"/>
                </StackPanel>
                <TextBlock Text="DOCUMENTOS TRIBUTARIOS ELECTRÓNICOS"
                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="15,6,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding NavigateToCreateDteCommand}"
                    Style="{StaticResource PrimaryButton}"
                    VerticalAlignment="Top" Padding="18,11">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource Icon_Plus}"
                          Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                    <TextBlock Text="Nueva Factura" Margin="8,0,0,0" Foreground="White" FontSize="13"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BgBorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource Icon_Filter}"
                          Fill="{DynamicResource TextMutedBrush}"
                          Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock Text="Documentos registrados en el período activo"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,12,0">
                        <Border.Background><SolidColorBrush Color="#1000D4FF"/></Border.Background>
                        <TextBlock Text="{Binding Dtes.Count, StringFormat='{}{0} registros'}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="4"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BgBorderBrush}"
                BorderThickness="1" CornerRadius="10" ClipToBounds="True">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Dtes.Count, Converter={StaticResource EmptyStringToVisibleConverter}, FallbackValue=Collapsed}">
                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="{DynamicResource BgHoverBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Path Data="{StaticResource Icon_Invoice}"
                              Fill="{DynamicResource TextMutedBrush}"
                              Width="28" Height="28" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Sin documentos" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Los DTEs emitidos aparecerán aquí"
                               FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding Dtes}"
                          Margin="0" IsReadOnly="True"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° CONTROL" Width="180"
                                            Binding="{Binding NumeroControl}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TIPO" Width="100"
                                            Binding="{Binding DteTypeName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="RECEPTOR" Width="*"
                                            Binding="{Binding ReceptorNombre}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="EMISIÓN" Width="130"
                                            Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TOTAL" Width="140"
                                            Binding="{Binding TotalPagar, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="ACCIONES" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource IconButton}"
                                            Command="{Binding DataContext.ExportToPdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Exportar PDF" Padding="6" Margin="10,0">
                                        <Path Data="{StaticResource Icon_Export}"
                                              Fill="{DynamicResource TextSecondaryBrush}"
                                              Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
