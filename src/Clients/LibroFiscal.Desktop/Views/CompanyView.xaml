<UserControl x:Class="LibroFiscal.Desktop.Views.CompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1020">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="36,32,36,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Height="28" CornerRadius="2"
                                Background="{DynamicResource EmeraldBrush}"
                                Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Empresa" Style="{StaticResource TextH1}"/>
                    </StackPanel>
                    <TextBlock Text="CONFIGURACIÓN DEL CONTRIBUYENTE (EMISOR)"
                               FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="15,6,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding SaveCompanyCommand}"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Top" Padding="22,11">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                              Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                        <TextBlock Text="Guardar Cambios" Margin="8,0,0,0" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Error banner -->
            <Border Grid.Row="1" Margin="0,-8,0,0"
                    Background="{DynamicResource DangerGlowGradient}"
                    BorderBrush="{DynamicResource DangerBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" FontSize="12"/>
            </Border>

            <!-- Cards grid -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Card: Información Legal -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="28" Height="28" CornerRadius="6">
                                <Border.Background><SolidColorBrush Color="#1500D4FF"/></Border.Background>
                                <Path Data="{StaticResource Icon_Company}"
                                      Fill="{DynamicResource PrimaryBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="INFORMACIÓN LEGAL" Style="{StaticResource TextLabel}"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Logo -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="72" Height="72" CornerRadius="8"
                                    Background="{DynamicResource BgHoverBrush}"
                                    BorderBrush="{DynamicResource BgBorderBrush}"
                                    BorderThickness="1" Margin="0,0,14,0">
                                <Image Source="{Binding LogoPath}" Stretch="Uniform" Margin="6"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Logo de la empresa" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <Button Command="{Binding SelectLogoCommand}"
                                        Style="{StaticResource OutlineButton}"
                                        Padding="12,7" FontSize="12">
                                    <TextBlock Text="Cambiar Logo" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="RAZÓN SOCIAL" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding RazonSocial, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                        <TextBlock Text="NOMBRE COMERCIAL" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NombreComercial, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="NIT" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Nit, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="NRC" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Nrc, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card: Contacto y Dirección -->
                <Border Grid.Row="0" Grid.Column="2"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="#1510B981">
                                <Path Data="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                                      Fill="{DynamicResource EmeraldBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="CONTACTO Y DIRECCIÓN" Style="{StaticResource TextLabel}"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TELÉFONO" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DEPARTAMENTO" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MUNICIPIO" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Municipality, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="DIRECCIÓN COMPLETA" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding AddressLine, UpdateSourceTrigger=PropertyChanged}"
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CÓD. ACTIVIDAD" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding CodigoActividad, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ACTIVIDAD ECONÓMICA" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding ActividadEconomica, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card: Integración Hacienda -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="28" Height="28" CornerRadius="6"
                                        Background="#15F59E0B">
                                    <Path Data="{StaticResource Icon_Settings}"
                                          Fill="{DynamicResource AmberBrush}"
                                          Width="14" Height="14" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="INTEGRACIÓN HACIENDA" Style="{StaticResource TextLabel}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="CLAVE API (FACTURACIÓN ELECTRÓNICA)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ApiPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BgHoverBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10"
                                             Fill="{DynamicResource AmberBrush}"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Ingrese su clave para activar la facturación electrónica DTE con el Ministerio de Hacienda de El Salvador."
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
