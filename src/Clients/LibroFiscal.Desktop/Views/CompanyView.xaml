<UserControl x:Class="LibroFiscal.Desktop.Views.CompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Configuración de la Empresa" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="DATOS DEL CONTRIBUYENTE (EMISOR)" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Command="{Binding SaveCompanyCommand}" Content="Guardar Perfil" Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" Padding="30,12" FontSize="14"/>
        </Grid>

        <!-- Formulario (2 Columnas) -->
        <Border Grid.Row="1" Background="{DynamicResource BgAppBrush}" CornerRadius="12" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="40">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Columna 1: Información Legal -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="INFORMACIÓN LEGAL" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="Razón Social" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding RazonSocial, UpdateSourceTrigger=PropertyChanged}" 
                             Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                             BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                             Padding="12,10" Height="42" Margin="0,0,0,20"/>

                    <TextBlock Text="Nombre Comercial" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NombreComercial, UpdateSourceTrigger=PropertyChanged}" 
                             Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                             BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                             Padding="12,10" Height="42" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="NIT" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Nit, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NRC" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Nrc, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Cód. Actividad" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding CodigoActividad, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Actividad Económica" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding ActividadEconomica, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Separador -->
                <Border Grid.Column="1" Width="1" Background="{DynamicResource BgBorderBrush}" Margin="19,0"/>

                <!-- Columna 2: Contacto y Dirección -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="CONTACTO Y DIRECCIÓN" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Teléfono" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Correo Electrónico" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Departamento" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Municipio" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Municipality, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                     BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                                     Padding="12,10" Height="42"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Dirección Completa (Complemento)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding AddressLine, UpdateSourceTrigger=PropertyChanged}" 
                             Background="{DynamicResource BgPanelBrush}" Foreground="{DynamicResource TextPrimaryBrush}" 
                             BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" 
                             Padding="12,10" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,15,0,0" TextWrapping="Wrap" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
