<UserControl x:Class="LibroFiscal.Desktop.Views.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:LibroFiscal.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:PurchasesViewModel}"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1020">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding LoadPurchasesCommand}"/>
    </UserControl.InputBindings>

    <Grid Margin="36,32,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="3" Height="28" CornerRadius="2"
                            Background="{DynamicResource EmeraldBrush}"
                            Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Libro de Compras" Style="{StaticResource TextH1}"/>
                </StackPanel>
                <TextBlock Text="REGISTRO HISTÓRICO DE DOCUMENTOS RECIBIDOS"
                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="15,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding ExportToCsvCommand}"
                        Style="{StaticResource OutlineButton}"
                        VerticalAlignment="Top" Padding="14,9" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↓" FontSize="14" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="Exportar CSV" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding LoadPurchasesCommand}"
                        Style="{StaticResource OutlineButton}"
                        VerticalAlignment="Top" Padding="14,9">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon_Refresh}"
                              Fill="{DynamicResource TextSecondaryBrush}"
                              Width="13" Height="13" Stretch="Uniform"/>
                        <TextBlock Text="Actualizar" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Error banner -->
        <Border Grid.Row="2"
                Background="{DynamicResource DangerGlowGradient}"
                BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="1" CornerRadius="6" Padding="12,10"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource Icon_Alert}"
                      Fill="{DynamicResource DangerBrush}"
                      Width="13" Height="13" Stretch="Uniform" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerBrush}" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="4"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BgBorderBrush}"
                BorderThickness="1" CornerRadius="10" ClipToBounds="True">
            <Grid>
                <DataGrid ItemsSource="{Binding Purchases}"
                          IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FECHA" Width="110"
                                            Binding="{Binding IssueDate, StringFormat=dd/MM/yyyy}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DOCUMENTO" Width="130"
                                            Binding="{Binding DocumentNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="NIT" Width="130"
                                            Binding="{Binding SupplierNit}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="PROVEEDOR" Width="*"
                                            Binding="{Binding SupplierName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="SUBTOTAL" Width="110"
                                            Binding="{Binding SubTotal, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="IVA" Width="100"
                                            Binding="{Binding TaxAmount, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AmberBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TOTAL" Width="120"
                                            Binding="{Binding TotalAmount, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{DynamicResource EmeraldBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading overlay -->
                <Border Background="#CC080B10" CornerRadius="10"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="24"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="..." Foreground="White" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Cargando compras..."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
