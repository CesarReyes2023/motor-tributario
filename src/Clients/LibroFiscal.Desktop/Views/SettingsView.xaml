<UserControl x:Class="LibroFiscal.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Configuración" Style="{StaticResource Header1}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Gestiona la seguridad y personalización de tu cuenta." 
                   Style="{StaticResource TextBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,32"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="700" HorizontalAlignment="Left" Width="700">
                
                <!-- Mensajes -->
                <Border Background="#1A4CAF50" BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#4CAF50" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>

                <Border Background="#1AF44336" BorderBrush="#F44336" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>

                <!-- Cuenta Section -->
                <Border Style="{StaticResource CardBorder}" Padding="32" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Perfil de Usuario" Style="{StaticResource Header2}" Margin="0,0,0,24"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="100" Height="100" CornerRadius="50" Background="{DynamicResource BgHoverBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" Margin="0,0,24,0" ClipToBounds="True">
                                <Image Source="{Binding ProfilePicturePath}" Stretch="UniformToFill">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProfilePicturePath}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Username}" Style="{StaticResource Header3}" Margin="0,0,0,8"/>
                                <Button Content="Cambiar Foto de Perfil" Command="{Binding ChangeProfilePictureCommand}" 
                                        Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Seguridad Section -->
                <Border Style="{StaticResource CardBorder}" Padding="32" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Cambiar Contraseña" Style="{StaticResource Header2}" Margin="0,0,0,24"/>

                        <StackPanel Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock Text="Contraseña Actual" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding CurrentPassword, UpdateSourceTrigger=PropertyChanged}" MaxWidth="400" HorizontalAlignment="Left" Width="400"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,0,0,16">
                            <TextBlock Text="Nueva Contraseña" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" MaxWidth="400" HorizontalAlignment="Left" Width="400"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,0,0,24">
                            <TextBlock Text="Confirmar Nueva Contraseña" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding ConfirmNewPassword, UpdateSourceTrigger=PropertyChanged}" MaxWidth="400" HorizontalAlignment="Left" Width="400"/>
                        </StackPanel>

                        <Button Grid.Row="4" Content="Actualizar Contraseña" Command="{Binding ChangePasswordCommand}" 
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Width="200" Height="42"/>
                    </Grid>
                </Border>

                <!-- Acciones Peligrosas -->
                <Border Style="{StaticResource CardBorder}" Padding="32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Gestión de Sesión" Style="{StaticResource Header2}" Margin="0,0,0,16" Foreground="#F44336"/>

                        <TextBlock Grid.Row="1" Text="Al cerrar sesión volverás a la pantalla de ingreso. Asegúrate de haber guardado todo tu trabajo." 
                                   Style="{StaticResource TextBody}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>

                        <Button Grid.Row="2" Content="Cerrar Sesión" Command="{Binding LogoutCommand}" 
                                Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Width="180" Height="42" Foreground="#F44336" BorderBrush="#F44336"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
