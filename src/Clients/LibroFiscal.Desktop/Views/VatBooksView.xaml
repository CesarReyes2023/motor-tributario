<UserControl x:Class="LibroFiscal.Desktop.Views.VatBooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:LibroFiscal.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:VatBooksViewModel}"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1100">

    <Grid Margin="36,32,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="3" Height="28" CornerRadius="2"
                            Background="{DynamicResource PrimaryBrush}"
                            Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedBookType}" Style="{StaticResource TextH1}"/>
                </StackPanel>
                <TextBlock Text="REPORTE FISCAL F-07 · DETALLE DE OPERACIONES Y TOTALES"
                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="15,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Filter bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BgBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="LIBRO:" Style="{StaticResource TextLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding BookTypes}"
                              SelectedItem="{Binding SelectedBookType}"
                              Width="240" Height="36" Margin="0,0,20,0"
                              FontSize="13" FontWeight="Medium"/>

                    <TextBlock Text="PERÍODO:" Style="{StaticResource TextLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Months}"
                              SelectedItem="{Binding SelectedMonth}"
                              DisplayMemberPath="Name"
                              Width="140" Height="36" Margin="0,0,8,0"
                              FontSize="13"/>
                    <ComboBox ItemsSource="{Binding Years}"
                              SelectedItem="{Binding SelectedYear}"
                              Width="88" Height="36" Margin="0,0,20,0"
                              FontSize="13"/>

                    <Button Command="{Binding GenerateReportCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="18,9" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Refresh}"
                                  Fill="White" Width="13" Height="13" Stretch="Uniform"/>
                            <TextBlock Text="Generar" Margin="8,0,0,0" Foreground="White" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ExportToCsvCommand}"
                            Style="{StaticResource OutlineButton}"
                            Padding="14,9" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Export}"
                                  Fill="{DynamicResource TextSecondaryBrush}"
                                  Width="13" Height="13" Stretch="Uniform"/>
                            <TextBlock Text="CSV" Margin="7,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportToF930Command}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Export}"
                                  Fill="White" Width="13" Height="13" Stretch="Uniform"/>
                            <TextBlock Text="Anexo F930 (MH)" Margin="8,0,0,0" Foreground="White" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Summary cards -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BgBorderBrush}"
                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                <Grid>
                    <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00D4FF" Offset="0"/>
                                <GradientStop Color="#0099BB" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Margin="20,14,20,14">
                        <TextBlock Text="TOTAL NETO OPERACIONES" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding TotalBase, StringFormat=C2}"
                                   Style="{StaticResource TextMetric}" FontSize="24"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BgBorderBrush}"
                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                <Grid>
                    <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F59E0B" Offset="0"/>
                                <GradientStop Color="#D97706" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Margin="20,14,20,14">
                        <TextBlock Text="IMPUESTOS (CRÉDITO / DÉBITO)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding TotalTaxes, StringFormat=C2}"
                                   Style="{StaticResource TextMetric}" FontSize="24"
                                   Foreground="{DynamicResource AmberBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Error banner -->
        <Border Grid.Row="5" Margin="0,-2,0,0"
                Background="{DynamicResource DangerGlowGradient}"
                BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="1" CornerRadius="6" Padding="12,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" FontSize="12"/>
        </Border>

        <!-- DataGrid container -->
        <Border Grid.Row="6"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BgBorderBrush}"
                BorderThickness="1" CornerRadius="10" ClipToBounds="True">
            <Grid>
                <!-- COMPRAS -->
                <DataGrid ItemsSource="{Binding VatPurchases}"
                          IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedBookType}" Value="Libro de Compras">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Width="40" Binding="{Binding RowNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="FECHA" Width="95" Binding="{Binding IssueDate, StringFormat=dd/MM/yyyy}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="N° DOC" Width="115" Binding="{Binding DocumentNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NIT" Width="130" Binding="{Binding SupplierNit}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="PROVEEDOR" Width="*" Binding="{Binding SupplierName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EXENTAS" Width="100" Binding="{Binding ExemptPurchases, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="GRAVADAS" Width="110" Binding="{Binding InternalPurchases, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="CRÉDITO FISCAL" Width="120" Binding="{Binding TaxCredit, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AmberBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TOTAL" Width="110" Binding="{Binding TotalPurchases, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource EmeraldBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- VENTAS CONTRIBUYENTES -->
                <DataGrid ItemsSource="{Binding VatSalesTaxpayer}"
                          IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedBookType}" Value="Libro de Ventas (Contribuyentes)">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FECHA" Width="95" Binding="{Binding EmisionDate, StringFormat=dd/MM/yyyy}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="N° CCF" Width="130" Binding="{Binding DocumentNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NRC" Width="100" Binding="{Binding NrcCustomer}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="CLIENTE" Width="*" Binding="{Binding CustomerName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EXENTAS" Width="110" Binding="{Binding ExemptSales, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="GRAVADAS" Width="110" Binding="{Binding LocalGravadaSales, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DÉBITO FISCAL" Width="120" Binding="{Binding FiscalDebit, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AmberBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TOTAL" Width="110" Binding="{Binding TotalSales, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- VENTAS CONSUMIDOR FINAL -->
                <DataGrid ItemsSource="{Binding VatSalesConsumer}"
                          IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedBookType}" Value="Libro de Ventas (Consumidor Final)">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FECHA" Width="95" Binding="{Binding EmisionDate, StringFormat=dd/MM/yyyy}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DEL N°" Width="130" Binding="{Binding InitialDocumentNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="AL N°" Width="130" Binding="{Binding FinalDocumentNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EXENTAS" Width="*" Binding="{Binding ExemptSales, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="GRAVADAS" Width="130" Binding="{Binding LocalGravadaSales, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="EXPORTACIONES" Width="130" Binding="{Binding ExportSales, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource VioletBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TOTAL VENTA" Width="130" Binding="{Binding TotalSales, StringFormat=C2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="Margin" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading overlay -->
                <Border Background="#CC080B10" CornerRadius="10"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="24"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="···" Foreground="White" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Generando Libro de IVA..."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
