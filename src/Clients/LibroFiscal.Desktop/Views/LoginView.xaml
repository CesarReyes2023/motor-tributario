<Window x:Class="LibroFiscal.Desktop.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:LibroFiscal.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="Libro Fiscal - Iniciar Sesión" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BgAppBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid>
        <Border Padding="30" CornerRadius="8" Background="{DynamicResource BgPanelBrush}"
                Margin="20" VerticalAlignment="Center" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel>

                <TextBlock Text="Bienvenido a el sistema de motor fiscal" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="{DynamicResource PrimaryBrush}" />

                <TextBlock Text="Usuario" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource BgAppBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1"
                         Padding="10" Margin="0,0,0,20" />

                <TextBlock Text="Contraseña" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5" />
                <!-- Usar PasswordBox en lugar de TextBox para contraseñas en WPF, pero para MVVM simple Binding, usamos TextBox con Font -->
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource BgAppBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1"
                         Padding="10" Margin="0,0,0,30" FontFamily="Password" />

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                           TextWrapping="Wrap" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <Button Command="{Binding LoginCommand}"
                        Content="INICIAR SESIÓN"
                        Style="{StaticResource PrimaryButton}"
                        Height="40" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
