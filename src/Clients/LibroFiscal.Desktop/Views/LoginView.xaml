<Window x:Class="LibroFiscal.Desktop.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Engine Fiscal — Acceso"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgAppBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStyle="None"
        AllowsTransparency="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>       <!-- Left panel (brand) -->
            <ColumnDefinition Width="460"/>     <!-- Right panel (form) -->
        </Grid.ColumnDefinitions>

        <!-- ════ LEFT BRAND PANEL ════ -->
        <Grid Grid.Column="0">
            <!-- Layered dark background -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#050709" Offset="0"/>
                        <GradientStop Color="#0A1220" Offset="0.5"/>
                        <GradientStop Color="#080B10" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Geometric decoration — large subtle circle -->
            <Ellipse Width="600" Height="600" Opacity="0.04"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-150,0,0,100">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00D4FF" Offset="0"/>
                        <GradientStop Color="#8B5CF6" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Smaller accent circle -->
            <Ellipse Width="300" Height="300" Opacity="0.06"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,80,80,0">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#00D4FF"/>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Grid line decoration -->
            <Border Opacity="0.03" IsHitTestVisible="False">
                <Border.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Pen>
                                    <Pen Brush="White" Thickness="0.5"/>
                                </GeometryDrawing.Pen>
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="40,0" EndPoint="40,40"/>
                                        <LineGeometry StartPoint="0,40" EndPoint="40,40"/>
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Border.Background>
            </Border>

            <!-- Content -->
            <StackPanel Margin="80" VerticalAlignment="Center">
                <!-- Logo -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,48">
                    <Border Width="42" Height="42" CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00D4FF" Offset="0"/>
                                <GradientStop Color="#0072AA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="{StaticResource Icon_Dashboard}"
                              Fill="White" Width="22" Height="22" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="22" FontWeight="Bold" Foreground="White" LineHeight="22">
                            <Run Text="ENGINE"/>
                            <Run Text="FISCAL" Foreground="#00D4FF"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Headline -->
                <TextBlock FontSize="48" FontWeight="Bold" LineHeight="56"
                           TextWrapping="Wrap" MaxWidth="560">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="#E8EDF5"/>
                    </TextBlock.Foreground>
                    <Run Text="Automatización"/>
                    <LineBreak/>
                    <Run Text="Tributaria"/>
                    <LineBreak/>
                    <Run Text="Inteligente" Foreground="#00D4FF"/>
                </TextBlock>

                <TextBlock Text="Facturación electrónica, OCR, libros IVA e ingesta masiva para El Salvador."
                           FontSize="15" LineHeight="24"
                           Foreground="#6B7FA3"
                           TextWrapping="Wrap" MaxWidth="500"
                           Margin="0,20,0,48"/>

                <!-- Feature list -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="20" Height="20" CornerRadius="10"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <SolidColorBrush Color="#1500D4FF"/>
                            </Border.Background>
                            <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                  Fill="#00D4FF" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Facturación Electrónica DTE" FontSize="14" Foreground="#A0B0C8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="20" Height="20" CornerRadius="10"
                                Background="#1510B981" Margin="0,0,12,0">
                            <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                  Fill="#10B981" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Libros IVA Automáticos" FontSize="14" Foreground="#A0B0C8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="20" Height="20" CornerRadius="10"
                                Background="#158B5CF6" Margin="0,0,12,0">
                            <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                  Fill="#8B5CF6" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="OCR Inteligente de Documentos" FontSize="14" Foreground="#A0B0C8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="20" Height="20" CornerRadius="10"
                                Background="#15F59E0B" Margin="0,0,12,0">
                            <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                  Fill="#F59E0B" Width="10" Height="10" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Ingesta Masiva XML y PDF" FontSize="14" Foreground="#A0B0C8" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bottom version -->
                <TextBlock Text="v2026.1 · Enterprise · El Salvador"
                           FontSize="11" Foreground="#3D4F6E"
                           Margin="0,60,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ════ RIGHT FORM PANEL ════ -->
        <Border Grid.Column="1"
                Background="{DynamicResource BgSidebarBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1,0,0,0">
            <Grid VerticalAlignment="Center" Margin="56,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="Auto"/>  <!-- Form -->
                    <RowDefinition Height="Auto"/>  <!-- Error -->
                    <RowDefinition Height="Auto"/>  <!-- Actions -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Bienvenido de vuelta"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Ingrese sus credenciales para acceder al sistema"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Form -->
                <StackPanel Grid.Row="2">
                    <!-- Usuario -->
                    <TextBlock Text="USUARIO" Style="{StaticResource TextLabel}" Margin="0,0,0,7"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Height="46" FontSize="14"/>

                    <!-- Password -->
                    <TextBlock Text="CONTRASEÑA" Style="{StaticResource TextLabel}" Margin="0,22,0,7"/>
                    <PasswordBox x:Name="txtPassword"
                                 Height="46" FontSize="14"
                                 PasswordChanged="TxtPassword_PasswordChanged"/>
                </StackPanel>

                <!-- Error -->
                <Border Grid.Row="3" Margin="0,14,0,0"
                        Background="{DynamicResource DangerGlowGradient}"
                        BorderBrush="{DynamicResource DangerBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon_Alert}"
                              Fill="{DynamicResource DangerBrush}"
                              Width="14" Height="14" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontSize="12" VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Grid.Row="4" Margin="0,28,0,0">
                    <CheckBox Content="Mantener sesión iniciada"
                              Margin="0,0,0,20"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="13"/>

                    <Button Content="INICIAR SESIÓN"
                            Height="50"
                            FontSize="13"
                            FontWeight="Bold"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButton}"/>

                    <TextBlock Text="César Reyes · 2026"
                               HorizontalAlignment="Center"
                               Margin="0,32,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>