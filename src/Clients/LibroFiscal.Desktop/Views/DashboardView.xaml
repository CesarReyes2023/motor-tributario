<UserControl x:Class="LibroFiscal.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
             
    <!-- Interacción para invocar LoadDashboardAsync al cargar la vista. Se puede hacer en code-behind o usando Behaviours. -->
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Dashboard General" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding CurrentMonthName, StringFormat='RESUMEN FISCAL DE {0}'}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0"/>
            </StackPanel>
            
            <Button Grid.Column="1" Command="{Binding LoadDashboardCommand}" Content="Actualizar Métricas" Style="{StaticResource OutlineButton}" VerticalAlignment="Center" Padding="20,10"/>
        </Grid>

        <!-- Cards Stats (4 Columnas) -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Ventas Mes -->
            <Border Grid.Column="0" Background="{DynamicResource BgAppBrush}" CornerRadius="12" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="💰 Ventas Netas" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalSales, StringFormat=C2}" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding TotalSalesTaxes, StringFormat='Débito Fiscal: {0:C2}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Compras Mes -->
            <Border Grid.Column="2" Background="{DynamicResource BgAppBrush}" CornerRadius="12" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="🛒 Compras Netas" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalPurchases, StringFormat=C2}" Foreground="#007ACC" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding TotalPurchaseTaxes, StringFormat='Crédito Fiscal: {0:C2}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Balance IVA -->
            <Border Grid.Column="4" Background="{DynamicResource BgAppBrush}" CornerRadius="12" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="⚖️ Balance de IVA" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding IvaBalance, StringFormat=C2}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                    <!-- Positivo: A pagar (Rojo/Naranja), Negativo: A favor (Verde/Azul) -->
                    <TextBlock Text="Neto entre Débito y Crédito" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Alertas -->
            <Border Grid.Column="6" Background="{DynamicResource BgAppBrush}" CornerRadius="12" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="⚠️ DTEs Pendientes" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PendingDtesCount}" Foreground="#D25C00" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="En Borrador o Rechazados" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Gráfico Comparativo / Visual representation -->
        <Border Grid.Row="2" Background="{DynamicResource BgAppBrush}" CornerRadius="12" BorderBrush="{DynamicResource BgBorderBrush}" BorderThickness="1" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Relación Comercial del Mes (Ventas vs Compras)" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                <!-- ProgressBar nativa estilizada -->
                <ProgressBar Grid.Row="1" Height="30" Minimum="0" Maximum="1" Value="{Binding SalesPercentage, Mode=OneWay}" 
                             Foreground="{DynamicResource PrimaryAccentBrush}" Background="#007ACC" BorderThickness="0" Margin="0,0,0,10">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <!-- Fondo (Compras) -->
                                <Border Background="{TemplateBinding Background}" CornerRadius="15"/>
                                <!-- Progreso (Ventas) -->
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="15" HorizontalAlignment="Left"/>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top">
                        <Ellipse Width="12" Height="12" Fill="{DynamicResource PrimaryAccentBrush}" Margin="0,0,5,0"/>
                        <TextBlock Text="Proporción Ventas" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                        <TextBlock Text="Proporción Compras" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                        <Ellipse Width="12" Height="12" Fill="#007ACC"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
