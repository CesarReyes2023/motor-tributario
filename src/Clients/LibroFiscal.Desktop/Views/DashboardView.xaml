<UserControl x:Class="LibroFiscal.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:LibroFiscal.Desktop.Converters"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1020">

    <UserControl.Resources>
        <converters:PercentageToWidthConverter x:Key="PercentageToWidthConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="36,32,36,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="28"/>    <!-- Spacer -->
                <RowDefinition Height="Auto"/>  <!-- KPI Cards -->
                <RowDefinition Height="28"/>    <!-- Spacer -->
                <RowDefinition Height="Auto"/>  <!-- Chart row -->
                <RowDefinition Height="28"/>    <!-- Spacer -->
                <RowDefinition Height="Auto"/>  <!-- Analytics row -->
            </Grid.RowDefinitions>

            <!-- ════ HEADER ════ -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Height="28" CornerRadius="2"
                                Background="{DynamicResource PrimaryBrush}"
                                Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Dashboard" Style="{StaticResource TextH1}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding CurrentMonthName, StringFormat='RESUMEN FISCAL — {0}'}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="15,6,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding LoadDashboardCommand}"
                        Style="{StaticResource OutlineButton}"
                        Padding="16,9" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon_Refresh}"
                              Fill="{DynamicResource TextSecondaryBrush}"
                              Width="14" Height="14" Stretch="Uniform"/>
                        <TextBlock Text="Actualizar" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ════ KPI CARDS ════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card: Ventas -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <!-- Top accent bar -->
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                    <GradientStop Color="#0099BB" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Margin="22,20,22,22">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="32" Height="32" CornerRadius="6"
                                        Background="{DynamicResource CyanGlowGradient}">
                                    <Path Data="{StaticResource Icon_Invoice}"
                                          Fill="{DynamicResource PrimaryBrush}"
                                          Width="16" Height="16" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="VENTAS NETAS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalSales, StringFormat=C2}"
                                       Style="{StaticResource TextMetric}"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding TotalSalesTaxes, StringFormat='Débito: {0:C2}'}"
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card: Compras -->
                <Border Grid.Column="2"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Margin="22,20,22,22">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="32" Height="32" CornerRadius="6"
                                        Background="{DynamicResource VioletGlowGradient}">
                                    <Path Data="{StaticResource Icon_Cart}"
                                          Fill="{DynamicResource VioletBrush}"
                                          Width="16" Height="16" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="COMPRAS NETAS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalPurchases, StringFormat=C2}"
                                       Style="{StaticResource TextMetric}"
                                       Foreground="{DynamicResource VioletBrush}"/>
                            <TextBlock Text="{Binding TotalPurchaseTaxes, StringFormat='Crédito: {0:C2}'}"
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card: Balance IVA -->
                <Border Grid.Column="4"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Margin="22,20,22,22">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="32" Height="32" CornerRadius="6"
                                        Background="{DynamicResource EmeraldGlowGradient}">
                                    <Path Data="{StaticResource Icon_Book}"
                                          Fill="{DynamicResource EmeraldBrush}"
                                          Width="16" Height="16" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="BALANCE IVA" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding IvaBalance, StringFormat=C2}"
                                       Style="{StaticResource TextMetric}"
                                       Foreground="{DynamicResource EmeraldBrush}"/>
                            <TextBlock Text="Débito − Crédito Fiscal"
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card: DTEs Pendientes -->
                <Border Grid.Column="6"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F59E0B" Offset="0"/>
                                    <GradientStop Color="#D97706" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <StackPanel Margin="22,20,22,22">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="32" Height="32" CornerRadius="6"
                                        Background="{DynamicResource AmberGlowGradient}">
                                    <Path Data="{StaticResource Icon_Alert}"
                                          Fill="{DynamicResource AmberBrush}"
                                          Width="16" Height="16" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="PENDIENTES" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding PendingDtesCount}"
                                       Style="{StaticResource TextMetric}"
                                       Foreground="{DynamicResource AmberBrush}"/>
                            <TextBlock Text="DTEs en borrador"
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════ VISUAL SECTION ════ -->
            <Border Grid.Row="4"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BgBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Relación Comercial del Período"
                                       Style="{StaticResource TextH2}"/>
                            <TextBlock Text="Distribución porcentual de Ventas vs Compras"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="Ventas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource VioletBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="Compras" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Progress bar ventas -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Ventas bar -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ventas Netas" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="8" CornerRadius="4"
                                    Background="{DynamicResource BorderSubtleBrush}" Margin="12,0">
                                <Border HorizontalAlignment="Left" CornerRadius="4"
                                        Width="{Binding SalesPercentage, Mode=OneWay, Converter={StaticResource PercentageToWidthConverter}, ConverterParameter='300'}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00D4FF" Offset="0"/>
                                            <GradientStop Color="#0099BB" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding TotalSales, StringFormat={}{0:C0}}"
                                       Style="{StaticResource TextMono}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Compras bar -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Compras Netas" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Height="8" CornerRadius="4"
                                    Background="{DynamicResource BorderSubtleBrush}" Margin="12,0">
                                <Border HorizontalAlignment="Left" CornerRadius="4">
                                    <Border.Width>
                                        <Binding Path="PurchasesPercentage" Mode="OneWay" Converter="{StaticResource PercentageToWidthConverter}" ConverterParameter="300"/>
                                    </Border.Width>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#8B5CF6" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding TotalPurchases, StringFormat={}{0:C0}}"
                                       Style="{StaticResource TextMono}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource VioletBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- IVA Balance row -->
                        <Border Grid.Row="4"
                                Background="{DynamicResource BgHoverBrush}"
                                CornerRadius="6" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource EmeraldBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Balance IVA Neto del período"
                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding IvaBalance, StringFormat={}{0:C2}}"
                                           Style="{StaticResource TextMono}"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource EmeraldBrush}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ════ GRAPHICS SECTION (PHASE 2) ════ -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bar Chart: Monthly Purchases -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Tendencia de Compras" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="Últimos 6 meses" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                        <!-- ItemsControl for Bar Chart -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding MonthlyPurchases}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5,0" VerticalAlignment="Bottom" Height="150" ToolTip="{Binding Amount, StringFormat=C2}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- The Bar -->
                                        <Border Grid.Row="0" Width="20" HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom"
                                                CornerRadius="4,4,0,0"
                                                Background="{DynamicResource VioletGlowGradient}">
                                            <Border.Height>
                                                <Binding Path="PercentageMax" Converter="{StaticResource PercentageToWidthConverter}" ConverterParameter="120"/>
                                            </Border.Height>
                                        </Border>
                                        <!-- Label -->
                                        <TextBlock Grid.Row="1" Text="{Binding MonthLabel}" 
                                                   FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Horizontal Stacked Bar (Tax Composition) -->
                <!-- ponytail: Shortcut taken: used horizontal stacked bar instead of literal donut to save 100 lines of math boilerplate. Upgrade path: add LiveCharts2 if strictly necessary. -->
                <Border Grid.Column="2"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Composición de Impuestos (Compras)" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="Proyección estimada en base al IVA" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                        <!-- The Stacked Bar -->
                        <Border Grid.Row="2" Height="16" CornerRadius="8" ClipToBounds="True" VerticalAlignment="Top">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition>
                                        <ColumnDefinition.Width>
                                            <Binding Path="TaxComposition.IvaPercentage" Converter="{StaticResource PercentageToWidthConverter}" ConverterParameter="100*"/>
                                        </ColumnDefinition.Width>
                                    </ColumnDefinition>
                                    <ColumnDefinition>
                                        <ColumnDefinition.Width>
                                            <Binding Path="TaxComposition.RentaPercentage" Converter="{StaticResource PercentageToWidthConverter}" ConverterParameter="100*"/>
                                        </ColumnDefinition.Width>
                                    </ColumnDefinition>
                                    <ColumnDefinition>
                                        <ColumnDefinition.Width>
                                            <Binding Path="TaxComposition.FovialPercentage" Converter="{StaticResource PercentageToWidthConverter}" ConverterParameter="100*"/>
                                        </ColumnDefinition.Width>
                                    </ColumnDefinition>
                                    <ColumnDefinition>
                                        <ColumnDefinition.Width>
                                            <Binding Path="TaxComposition.CotransPercentage" Converter="{StaticResource PercentageToWidthConverter}" ConverterParameter="100*"/>
                                        </ColumnDefinition.Width>
                                    </ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Background="{DynamicResource EmeraldBrush}" ToolTip="{Binding TaxComposition.Iva, StringFormat=IVA: {0:C2}}"/>
                                <Border Grid.Column="1" Background="{DynamicResource AmberBrush}" ToolTip="{Binding TaxComposition.Renta, StringFormat=Renta: {0:C2}}"/>
                                <Border Grid.Column="2" Background="{DynamicResource PrimaryBrush}" ToolTip="{Binding TaxComposition.Fovial, StringFormat=FOVIAL: {0:C2}}"/>
                                <Border Grid.Column="3" Background="{DynamicResource DangerBrush}" ToolTip="{Binding TaxComposition.Cotrans, StringFormat=COTRANS: {0:C2}}"/>
                            </Grid>
                        </Border>

                        <!-- Legend -->
                        <StackPanel Grid.Row="2" Margin="0,30,0,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{DynamicResource EmeraldBrush}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="IVA (Crédito Fiscal)" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding TaxComposition.Iva, StringFormat=C2}" Foreground="{DynamicResource EmeraldBrush}" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{DynamicResource AmberBrush}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="Retención Renta (Estimada)" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding TaxComposition.Renta, StringFormat=C2}" Foreground="{DynamicResource AmberBrush}" FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="FOVIAL (Contribución)" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding TaxComposition.Fovial, StringFormat=C2}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            
        </Grid>
    </ScrollViewer>
</UserControl>
