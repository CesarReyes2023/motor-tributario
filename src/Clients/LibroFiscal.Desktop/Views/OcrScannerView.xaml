<UserControl x:Class="LibroFiscal.Desktop.Views.OcrScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:LibroFiscal.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:OcrScannerViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Escáner Inteligente de Facturas (OCR)" FontSize="24" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,20"/>

        <!-- Top Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Command="{Binding SelectImageCommand}" Content="Seleccionar Imagen" Padding="15,10" Background="#1E3A8A" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,10,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <Button Command="{Binding ScanImageCommand}" Content="Escanear y Extraer Datos" Padding="15,10" Background="#10B981" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <TextBlock Text="Procesando imagen con IA..." VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#6B7280" FontStyle="Italic">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Main Content (2 columns) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Image Preview & Raw Text -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Previsualización" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
                
                <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="5" Background="#F9FAFB" Margin="0,0,0,15">
                    <Grid>
                        <TextBlock Text="Ninguna imagen seleccionada" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#9CA3AF"
                                   Visibility="{Binding ImagePath, Converter={StaticResource EmptyStringToVisibleConverter}}"/>
                        
                        <Image Source="{Binding ImagePreviewPath}" Stretch="Uniform" Margin="10" 
                               Visibility="{Binding IsImageFile, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                               
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    Visibility="{Binding IsPdfFile, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Documento PDF Cargado" FontWeight="SemiBold" Foreground="#4B5563" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ImagePath}" Foreground="#9CA3AF" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <TextBlock Grid.Row="2" Text="Texto Plano Extraído" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#374151"/>
                <TextBox Grid.Row="3" Text="{Binding ExtractedText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto" Padding="10" Background="#F3F4F6" BorderBrush="#E5E7EB" FontFamily="Consolas" FontSize="11"/>
            </Grid>

            <!-- Right: Extracted Data -->
            <Border Grid.Column="2" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="White" Padding="20">
                <StackPanel>
                    <TextBlock Text="Datos Fiscales Detectados" FontSize="18" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,20"/>

                    <!-- NIT -->
                    <TextBlock Text="NIT del Emisor / Receptor" FontWeight="Medium" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NitDetectado, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="SemiBold" Foreground="#111827" 
                             Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" Padding="8" Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- NRC -->
                    <TextBlock Text="NRC (Registro de Contribuyente)" FontWeight="Medium" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NrcDetectado, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="SemiBold" Foreground="#111827" 
                             Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" Padding="8" Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Fecha -->
                    <TextBlock Text="Fecha de Emisión" FontWeight="Medium" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding FechaDetectada, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="SemiBold" Foreground="#111827" 
                             Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" Padding="8" Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- IVA -->
                    <TextBlock Text="Impuesto IVA" FontWeight="Medium" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding IvaDetectado, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="SemiBold" Foreground="#111827" 
                             Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" Padding="8" Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- Total -->
                    <TextBlock Text="Total a Pagar / Monto Total" FontWeight="Medium" Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TotalDetectado, UpdateSourceTrigger=PropertyChanged}" FontSize="24" FontWeight="Bold" Foreground="#4338CA" 
                             Background="#EEF2FF" BorderBrush="#818CF8" BorderThickness="1" Padding="8" Margin="0,0,0,20">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Content="Registrar Compra" Command="{Binding RegistrarCompraCommand}"
                            Background="#10B981" Foreground="White" FontWeight="SemiBold" FontSize="16" 
                            Padding="0,12" BorderThickness="0" Margin="0,10,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
