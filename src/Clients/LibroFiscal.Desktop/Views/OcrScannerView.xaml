<UserControl x:Class="LibroFiscal.Desktop.Views.OcrScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:LibroFiscal.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:OcrScannerViewModel}"
             mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1020">

    <Grid Margin="36,32,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="3" Height="28" CornerRadius="2"
                            Background="{DynamicResource AmberBrush}"
                            Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Lector OCR" Style="{StaticResource TextH1}"/>
                </StackPanel>
                <TextBlock Text="ESCÁNER INTELIGENTE DE DOCUMENTOS TRIBUTARIOS"
                           FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="15,6,0,0"/>
            </StackPanel>

            <!-- Processing indicator -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource AmberBrush}"
                    BorderThickness="1" CornerRadius="20" Padding="14,6"
                    Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Background><SolidColorBrush Color="#20F59E0B"/></Border.Background>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AmberBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Procesando con IA..."
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AmberBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Action toolbar -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BgBorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SelectImageCommand}"
                        Style="{StaticResource OutlineButton}"
                        Padding="16,9" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon_Filter}"
                              Fill="{DynamicResource TextSecondaryBrush}"
                              Width="14" Height="14" Stretch="Uniform"/>
                        <TextBlock Text="Seleccionar Imagen" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ScanImageCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,9"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon_Scan}"
                              Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                        <TextBlock Text="Escanear y Extraer Datos" Margin="8,0,0,0" Foreground="White" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main split layout -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Preview + Extracted text -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>

                <!-- Image preview -->
                <Border Grid.Row="0"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                    <Grid>
                        <!-- Empty state -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding ImagePath, Converter={StaticResource EmptyStringToVisibleConverter}}">
                            <Border Width="60" Height="60" CornerRadius="30"
                                    Background="{DynamicResource BgHoverBrush}"
                                    HorizontalAlignment="Center" Margin="0,0,0,14">
                                <Path Data="{StaticResource Icon_Scan}"
                                      Fill="{DynamicResource TextMutedBrush}"
                                      Width="26" Height="26" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Sin imagen seleccionada"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Selecciona una imagen o PDF para comenzar"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- Image -->
                        <Image Source="{Binding ImagePreviewPath}" Stretch="Uniform"
                               Margin="16"
                               Visibility="{Binding IsImageFile, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- PDF icon -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsPdfFile, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Width="72" Height="88" CornerRadius="6"
                                    HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#20EF4444" Offset="0"/>
                                        <GradientStop Color="#10EF4444" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="PDF" FontWeight="Bold" FontSize="22"
                                           Foreground="{DynamicResource DangerBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Documento PDF cargado"
                                       FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ImagePath}"
                                       FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"
                                       TextWrapping="Wrap" MaxWidth="280"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Raw text -->
                <Border Grid.Row="2"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BgBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="14,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="TEXTO PLANO EXTRAÍDO"
                                   Style="{StaticResource TextLabel}"/>
                        <TextBox Grid.Row="2"
                                 Text="{Binding ExtractedText, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: Extracted fields -->
            <Border Grid.Column="2"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BgBorderBrush}"
                    BorderThickness="1" CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,22,22,24">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="#15F59E0B">
                                <Path Data="{StaticResource Icon_Invoice}"
                                      Fill="{DynamicResource AmberBrush}"
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="DATOS FISCALES DETECTADOS"
                                       Style="{StaticResource TextLabel}"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="PROVEEDOR" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding ProveedorDetectado, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Text="N° DOCUMENTO" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding NumeroDocumentoDetectado, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="NIT" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding NitDetectado, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="NRC" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding NrcDetectado, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="FECHA DE EMISIÓN" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FechaDetectada, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="IVA" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding IvaDetectado, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas" Foreground="{DynamicResource AmberBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TOTAL" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding TotalDetectado, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                         Foreground="{DynamicResource EmeraldBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Background="{DynamicResource BgBorderBrush}" Margin="0,4,0,18"/>

                        <Button Command="{Binding RegistrarCompraCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Height="46" FontSize="13">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Cart}"
                                      Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                                <TextBlock Text="Registrar Compra" Margin="10,0,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
